#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/async/caldav/version"

USAGE = <<~TEXT
  Usage: bin/increment-version <major|minor|patch>
TEXT

segment = ARGV[0]

unless %w[major minor patch].include?(segment)
  warn USAGE
  exit 1
end

current = Async::Caldav::VERSION
major, minor, patch = current.split(".").map(&:to_i)

case segment
when "major"
  major += 1
  minor = 0
  patch = 0
when "minor"
  minor += 1
  patch = 0
when "patch"
  patch += 1
end

version = "#{major}.#{minor}.#{patch}"

output_path = File.expand_path("../lib/async/caldav/version.rb", __dir__)

File.write(output_path, <<~RUBY)
  # frozen_string_literal: true

  module Async
    module Caldav
      VERSION = "#{version}"
    end
  end
RUBY

`bundle install`

puts "#{current} -> #{version}"
